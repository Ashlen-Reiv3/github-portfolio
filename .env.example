# Supabase — powers the home-page view counter.
# The anon (public) key is safe to expose in a static client build; Row-Level
# Security protects the data. Copy this file to `.env` and fill in your values.
# For the GitHub Actions build, set these two as repository *Variables* and pass
# them into the build step's env.
PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
