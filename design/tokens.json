{
  "$schema": "https://schemas.designtokens.org/tokens.json",
  "$description": "Portable design tokens for the Analytica portfolio. Generated from src/styles/tokens.css — that CSS file is the runtime source of truth; regenerate this JSON when it changes. Colour tokens are split into `light` (default :root) and `dark` ([data-theme=\"dark\"]); type/space/shape/effect tokens are theme-independent.",
  "light": {
    "$description": "Default :root theme — warm paper, teal primary, signal-orange accent.",
    "color": {
      "accent": { "$type": "color", "$value": "#0a6b5e", "$description": "teal-green primary — ~5.3:1 on canvas (AA text/links)" },
      "accent-strong": { "$type": "color", "$value": "#08574c", "$description": "accent hover" },
      "accent-contrast": { "$type": "color", "$value": "#ffffff", "$description": "text on accent" },
      "accent-2": { "$type": "color", "$value": "#e4572e", "$description": "alias of signal (back-compat)" },
      "signal": { "$type": "color", "$value": "#e4572e", "$description": "orange — large/graphical use ~3.9:1" },
      "signal-strong": { "$type": "color", "$value": "#c8431d" },
      "teal-tint": { "$type": "color", "$value": "#e1f1ec" },
      "teal-ink": { "$type": "color", "$value": "#08574c" },
      "orange-tint": { "$type": "color", "$value": "#fbeae2" },
      "orange-ink": { "$type": "color", "$value": "#8a3318" },
      "bg": { "$type": "color", "$value": "#faf9f6", "$description": "canvas — warm paper, never pure white" },
      "surface": { "$type": "color", "$value": "#ffffff" },
      "surface-2": { "$type": "color", "$value": "#f2f0ea" },
      "text": { "$type": "color", "$value": "#1a1c20", "$description": "warm ink — ~15:1 on canvas" },
      "muted": { "$type": "color", "$value": "#595d67", "$description": "~6.2:1 on canvas (AA body)" },
      "faint": { "$type": "color", "$value": "#6e727b", "$description": "~4.6:1 on canvas" },
      "border": { "$type": "color", "$value": "#e3e0d8" },
      "border-strong": { "$type": "color", "$value": "#cfccbf" },
      "grid-line": { "$type": "color", "$value": "#e7e3d8", "$description": "graph-paper texture" }
    },
    "series": {
      "$description": "Chart series — colourblind-aware; ALWAYS pair with shape/dash.",
      "1": { "$type": "color", "$value": "#0a6b5e" },
      "2": { "$type": "color", "$value": "#e4572e" },
      "3": { "$type": "color", "$value": "#3a6ea5" },
      "4": { "$type": "color", "$value": "#b5179e" },
      "5": { "$type": "color", "$value": "#6a8e1f" },
      "6": { "$type": "color", "$value": "#8c6a4a" }
    }
  },
  "dark": {
    "$description": "[data-theme=\"dark\"] theme — brightened teal/orange on near-black warm ink.",
    "color": {
      "accent": { "$type": "color", "$value": "#4fd1b5", "$description": "brightened teal — AA on dark" },
      "accent-strong": { "$type": "color", "$value": "#6fe0c7" },
      "accent-contrast": { "$type": "color", "$value": "#06241f", "$description": "dark ink on bright teal" },
      "accent-2": { "$type": "color", "$value": "#ff7a4d" },
      "signal": { "$type": "color", "$value": "#ff7a4d" },
      "signal-strong": { "$type": "color", "$value": "#ff8f69" },
      "teal-tint": { "$type": "color", "$value": "#11302a" },
      "teal-ink": { "$type": "color", "$value": "#7fe6cf" },
      "orange-tint": { "$type": "color", "$value": "#2e1a12" },
      "orange-ink": { "$type": "color", "$value": "#ffb191" },
      "bg": { "$type": "color", "$value": "#0e1014", "$description": "not pure black" },
      "surface": { "$type": "color", "$value": "#161a20" },
      "surface-2": { "$type": "color", "$value": "#1e232b" },
      "text": { "$type": "color", "$value": "#eceae3", "$description": "warm off-white — ~14:1 on canvas" },
      "muted": { "$type": "color", "$value": "#9aa0ac", "$description": "~6:1 on canvas" },
      "faint": { "$type": "color", "$value": "#7e8590" },
      "border": { "$type": "color", "$value": "#2a2f38" },
      "border-strong": { "$type": "color", "$value": "#3a4150" },
      "grid-line": { "$type": "color", "$value": "rgba(255, 255, 255, 0.045)" }
    },
    "series": {
      "1": { "$type": "color", "$value": "#4fd1b5" },
      "2": { "$type": "color", "$value": "#ff7a4d" },
      "3": { "$type": "color", "$value": "#6fa8dc" },
      "4": { "$type": "color", "$value": "#e879c9" },
      "5": { "$type": "color", "$value": "#a6c44e" },
      "6": { "$type": "color", "$value": "#c2a079" }
    }
  },
  "font": {
    "family": {
      "display": { "$type": "fontFamily", "$value": ["Fraunces Variable", "Georgia", "Times New Roman", "serif"] },
      "sans": { "$type": "fontFamily", "$value": ["IBM Plex Sans", "system-ui", "-apple-system", "BlinkMacSystemFont", "Segoe UI", "Roboto", "sans-serif"] },
      "mono": { "$type": "fontFamily", "$value": ["IBM Plex Mono", "ui-monospace", "SFMono-Regular", "Cascadia Code", "Consolas", "monospace"] }
    },
    "scale": {
      "$description": "Fluid modular scale ~1.25, 16px base. Values are CSS clamp() expressions (min / preferred / max).",
      "step--1": { "$type": "dimension", "$value": "clamp(0.80rem, 0.76rem + 0.18vw, 0.89rem)" },
      "step-0": { "$type": "dimension", "$value": "clamp(1.00rem, 0.95rem + 0.24vw, 1.13rem)" },
      "step-1": { "$type": "dimension", "$value": "clamp(1.25rem, 1.16rem + 0.45vw, 1.50rem)" },
      "step-2": { "$type": "dimension", "$value": "clamp(1.56rem, 1.40rem + 0.80vw, 2.00rem)" },
      "step-3": { "$type": "dimension", "$value": "clamp(1.95rem, 1.69rem + 1.30vw, 2.67rem)" },
      "step-4": { "$type": "dimension", "$value": "clamp(2.44rem, 2.02rem + 2.10vw, 3.55rem)" },
      "step-5": { "$type": "dimension", "$value": "clamp(3.05rem, 2.38rem + 3.35vw, 4.74rem)", "$description": "hero display" }
    },
    "leading": {
      "display": { "$type": "number", "$value": 1.08 },
      "body": { "$type": "number", "$value": 1.6 }
    }
  },
  "space": {
    "$description": "4px base scale.",
    "1": { "$type": "dimension", "$value": "0.5rem" },
    "2": { "$type": "dimension", "$value": "0.75rem" },
    "3": { "$type": "dimension", "$value": "1rem" },
    "4": { "$type": "dimension", "$value": "1.5rem" },
    "5": { "$type": "dimension", "$value": "2rem" },
    "6": { "$type": "dimension", "$value": "3rem" },
    "7": { "$type": "dimension", "$value": "5rem" }
  },
  "radius": {
    "base": { "$type": "dimension", "$value": "10px" },
    "lg": { "$type": "dimension", "$value": "16px" },
    "pill": { "$type": "dimension", "$value": "999px" }
  },
  "size": {
    "container": { "$type": "dimension", "$value": "1120px" },
    "measure": { "$type": "dimension", "$value": "68ch", "$description": "max reading width" }
  },
  "shadow": {
    "light": { "$type": "shadow", "$value": "0 1px 2px rgba(26,28,32,.04), 0 10px 30px rgba(26,28,32,.07)" },
    "dark": { "$type": "shadow", "$value": "0 1px 2px rgba(0,0,0,.3), 0 12px 34px rgba(0,0,0,.45)" }
  }
}
