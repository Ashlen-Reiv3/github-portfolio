---
// The signature "xStat" card: big tabular number + sparkline + data-lineage chip.
interface Props {
  value: string;
  unit?: string;
  label: string;
  spark?: number[];
  lineage?: string[];
  tone?: 'teal' | 'signal';
  class?: string;
}
const {
  value,
  unit,
  label,
  spark = [],
  lineage = ['source', 'SQL', 'analysis', 'viz'],
  tone = 'teal',
  class: className = '',
} = Astro.props;

// Build a normalised sparkline polyline (viewBox 0 0 88 28).
const W = 88, H = 28, PAD = 3;
let points = '';
if (spark.length > 1) {
  const min = Math.min(...spark), max = Math.max(...spark);
  const span = max - min || 1;
  points = spark
    .map((v, i) => {
      const x = PAD + (i * (W - PAD * 2)) / (spark.length - 1);
      const y = H - PAD - ((v - min) / span) * (H - PAD * 2);
      return `${x.toFixed(1)},${y.toFixed(1)}`;
    })
    .join(' ');
}
const stroke = tone === 'signal' ? 'var(--signal)' : 'var(--accent)';
---

<div class={`statcard kpi ${className}`} data-tone={tone}>
  <p class="sc-label">{label}</p>
  <div class="sc-row">
    <span class="sc-value">{value}{unit && <span class="sc-unit">{unit}</span>}</span>
    {points && (
      <svg class="sc-spark" viewBox="0 0 88 28" width="88" height="28" aria-hidden="true" preserveAspectRatio="none">
        <polyline points={points} fill="none" stroke={stroke} stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    )}
  </div>
  <div class="sc-lineage" aria-label={`Data lineage: ${lineage.join(' to ')}`}>
    <svg viewBox="0 0 24 24" width="13" height="13" aria-hidden="true" class="sc-db" fill="none" stroke="currentColor" stroke-width="2">
      <ellipse cx="12" cy="6" rx="7" ry="3" /><path d="M5 6v12c0 1.7 3.1 3 7 3s7-1.3 7-3V6" /><path d="M5 12c0 1.7 3.1 3 7 3s7-1.3 7-3" />
    </svg>
    {lineage.map((step, i) => (
      <>
        <span class={i === lineage.length - 1 ? 'sc-step sc-step-last' : 'sc-step'}>{step}</span>
        {i < lineage.length - 1 && <span class="sc-sep" aria-hidden="true">›</span>}
      </>
    ))}
  </div>
</div>

<style>
  .statcard {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: var(--radius); padding: var(--sp-3) var(--sp-3) calc(var(--sp-2) + 2px);
    display: inline-flex; flex-direction: column; gap: 6px; min-width: 0;
  }
  .sc-label { font-family: var(--font-mono); font-size: 10.5px; letter-spacing: .08em; text-transform: uppercase; color: var(--muted); }
  .sc-row { display: flex; align-items: flex-end; justify-content: space-between; gap: var(--sp-3); }
  .sc-value { font-family: var(--font-display); font-weight: 600; font-size: var(--step-3); line-height: 1; color: var(--text); }
  .sc-unit { font-size: 0.5em; color: var(--accent); margin-left: 1px; }
  [data-tone='signal'] .sc-unit { color: var(--signal); }
  .sc-spark { flex: none; opacity: .95; }
  .sc-lineage {
    display: flex; align-items: center; gap: 6px; flex-wrap: wrap;
    margin-top: 4px; padding-top: 8px; border-top: 1px solid var(--border);
    font-family: var(--font-mono); font-size: 10px;
  }
  .sc-db { color: var(--accent); flex: none; }
  .sc-step { color: var(--accent); }
  .sc-step-last { color: var(--signal); }
  .sc-sep { color: var(--faint); }
</style>
