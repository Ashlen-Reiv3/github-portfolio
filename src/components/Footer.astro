---
const year = new Date().getFullYear();
const socials = [
  { href: 'https://www.linkedin.com/in/ashlen-mammen-074903141/', label: 'LinkedIn' },
  { href: 'https://github.com/Ashlen-Reiv3', label: 'GitHub' },
  { href: 'mailto:ashlenmammen+portfolio@gmail.com', label: 'Email' },
];
---

<footer class="site-footer">
  <div class="container footer-inner">
    <div>
      <p class="footer-brand">Ashlen Mammen</p>
      <p class="muted footer-meta">© {year} · Built with Astro, no template.</p>
    </div>
    <ul class="footer-social">
      {socials.map((s) => (
        <li><a href={s.href} target="_blank" rel="noopener">{s.label} <span aria-hidden="true">↗</span></a></li>
      ))}
    </ul>
  </div>
</footer>

<style>
  .site-footer { border-top: 1px solid var(--border); margin-top: var(--sp-7); background: var(--surface-2); }
  .footer-inner { display: flex; align-items: flex-end; justify-content: space-between; gap: var(--sp-4); padding-block: var(--sp-5); flex-wrap: wrap; }
  .footer-brand { font-family: var(--font-display); font-weight: 600; font-size: var(--step-1); letter-spacing: -0.01em; }
  .footer-meta { font-size: var(--step--1); margin-top: 2px; }
  .footer-social { display: flex; gap: var(--sp-4); }
  .footer-social a { font-family: var(--font-mono); font-size: var(--step--1); color: var(--muted); text-decoration: none; transition: color .15s ease; }
  .footer-social a:hover { color: var(--accent); }
</style>
